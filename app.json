{
  "name": "Derci CRM",
  "description": "CRM para clínica de psicologia: pacientes, agenda, planos, tarefas, financeiro e relatórios.",
  "repository": "https://example.com/derci-crm",
  "logo": "https://avatars.githubusercontent.com/u/9919?s=200&v=4",
  "keywords": ["nextjs", "prisma", "psicologia", "crm"],
  "stack": "heroku-22",
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0"
    }
  ],
  "buildpacks": [{ "url": "heroku/nodejs" }],
  "env": {
    "AUTH_SECRET": {
      "description": "Segredo para assinar JWTs (gere com: openssl rand -base64 48)",
      "generator": "secret"
    },
    "NEXT_PUBLIC_APP_URL": {
      "description": "URL pública da aplicação (ex.: https://seu-app.herokuapp.com)",
      "value": ""
    },
    "SEED_ADMIN_EMAIL": {
      "description": "E-mail do usuário admin criado pelo seed",
      "value": "admin@derci.local"
    },
    "SEED_ADMIN_PASSWORD": {
      "description": "Senha do usuário admin criado pelo seed",
      "value": "admin123"
    },
    "SEED_ADMIN_NAME": {
      "description": "Nome do usuário admin",
      "value": "Administradora"
    },
    "NODE_ENV": {
      "value": "production"
    }
  },
  "scripts": {
    "postdeploy": "npx prisma db seed"
  }
}
