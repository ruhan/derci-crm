# Banco de dados PostgreSQL
DATABASE_URL="postgresql://derci:derci@localhost:5432/derci?schema=public"

# Chave de assinatura JWT (32+ caracteres). Em produção, gere uma forte com:
#   openssl rand -base64 48
AUTH_SECRET="troque-este-segredo-em-producao-com-32-caracteres-ou-mais"

# URL pública da aplicação (usada no link compartilhável de pacientes via WhatsApp)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Senha do usuário admin criado pelo seed
SEED_ADMIN_EMAIL="admin@derci.local"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Administradora"

# Em Heroku, adicionar ?sslmode=require ao DATABASE_URL ou definir PRISMA_PG_SSL=require
NODE_ENV="development"
